interface PortfolioData {
  totalValue: number;
  totalInvested: number;
  totalReturns: number;
  xirr: number;
  monthlySIP: number;
  activeSIPs: number;
  healthScore: number;
  fundsAtRisk: number;
  fundsCount: number;
}

interface Fund {
  name: string;
  category: string;
  invested: number;
  currentValue: number;
  returns: number;
  xirr: number;
  rating: string;
  risk: string;
  sipAmount: number;
  allocation: number;
}

interface AIInsight {
  id: string;
  type: "warning" | "info" | "critical" | "success";
  title: string;
  description: string;
  action: string;
  impact: string;
  icon: any;
}

interface Recommendation {
  id: string;
  type: "switch" | "add" | "reduce" | "rebalance";
  fromFund?: string;
  toFund?: string;
  category?: string;
  reason: string;
  potentialReturn: string;
  riskLevel: string;
  confidence: number;
}

interface ChatMessage {
  role: "user" | "assistant";
  content: string;
  timestamp: Date;
}

interface Prediction {
  period: string;
  projectedValue: number;
  projectedReturns: number;
  confidence: number;
  scenario: "optimistic" | "base" | "pessimistic";
}

