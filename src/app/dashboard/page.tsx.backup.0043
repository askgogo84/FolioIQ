                  </button>
                  <button className="p-2 hover:bg-slate-800 rounded-lg transition-colors">
                    <Filter className="w-4 h-4 text-slate-400" />
                  </button>
                  <button className="p-2 hover:bg-slate-800 rounded-lg transition-colors">
                    <Download className="w-4 h-4 text-slate-400" />
                  </button>
                </div>
              </div>
              <div className="overflow-x-auto">
                <table className="w-full">
                  <thead>
                    <tr className="border-b border-slate-800">
                      <th className="text-left px-6 py-3 text-xs font-medium text-slate-500 uppercase">Fund</th>
                      <th className="text-left px-6 py-3 text-xs font-medium text-slate-500 uppercase">Category</th>
                      <th className="text-right px-6 py-3 text-xs font-medium text-slate-500 uppercase">Invested</th>
                      <th className="text-right px-6 py-3 text-xs font-medium text-slate-500 uppercase">Value</th>
                      <th className="text-right px-6 py-3 text-xs font-medium text-slate-500 uppercase">Returns</th>
                      <th className="text-right px-6 py-3 text-xs font-medium text-slate-500 uppercase">XIRR</th>
                      <th className="text-center px-6 py-3 text-xs font-medium text-slate-500 uppercase">Rating</th>
                    </tr>
                  </thead>
                  <tbody>
                    {funds.map((fund, idx) => {
                      const isPositive = fund.returns > 0;
                      const isGradeA = fund.rating.startsWith("A");
                      const isGradeB = fund.rating === "B";

                      return (
                        <motion.tr key={idx} initial={{ opacity: 0 }} animate={{ opacity: 1 }} transition={{ delay: idx * 0.05 }}
                          className="border-b border-slate-800/50 hover:bg-slate-800/30 transition-colors">
                          <td className="px-6 py-4">
                            <div className="font-medium text-white text-sm">{fund.name}</div>
                            <div className="text-xs text-slate-500">SIP: Rs.{(fund.sipAmount / 1000).toFixed(0)}K</div>
                          </td>
                          <td className="px-6 py-4">
                            <span className="px-2.5 py-1 bg-slate-800 rounded-full text-xs text-slate-400">{fund.category}</span>
                          </td>
                          <td className="px-6 py-4 text-right text-sm text-slate-300">{formatCurrency(fund.invested)}</td>
                          <td className="px-6 py-4 text-right text-sm text-white font-medium">{formatCurrency(fund.currentValue)}</td>
                          <td className="px-6 py-4 text-right">
                            <span className={cn("text-sm font-medium", isPositive ? "text-emerald-400" : "text-red-400")}>
                              {isPositive ? "+" : ""}{fund.returns.toFixed(1)}%
                            </span>
                          </td>
                          <td className="px-6 py-4 text-right text-sm text-slate-300">{fund.xirr.toFixed(1)}%</td>
                          <td className="px-6 py-4 text-center">
                            <span className={cn(
                              "inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium",
                              isGradeA ? "bg-emerald-500/10 text-emerald-400" :
                              isGradeB ? "bg-amber-500/10 text-amber-400" :
                              "bg-red-500/10 text-red-400"
                            )}>
                              <Star className="w-3 h-3" /> {fund.rating}
                            </span>
                          </td>
                        </motion.tr>
                      );
                    })}
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        )}

        {/* AI RECOMMENDATIONS TAB */}
        {activeTab === "recommendations" && (
          <div className="space-y-6">
            <div className="flex items-center justify-between">
              <div>
                <h2 className="text-2xl font-bold text-white flex items-center gap-2">
                  <Lightbulb className="w-6 h-6 text-emerald-400" /> AI Recommendations
                </h2>
                <p className="text-slate-400 mt-1">Personalized suggestions based on your portfolio analysis</p>
              </div>
              <div className="flex items-center gap-2 px-4 py-2 bg-emerald-500/10 rounded-xl">
                <Brain className="w-4 h-4 text-emerald-400" />
                <span className="text-sm text-emerald-400 font-medium">AI Confidence: 91%</span>
              </div>
            </div>

            {recommendations.map((rec, idx) => {
              const isSwitch = rec.type === "switch";
              const isAdd = rec.type === "add";

              return (
                <motion.div key={rec.id} initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }} transition={{ delay: idx * 0.1 }}
                  className="bg-slate-900/60 border border-slate-800 rounded-2xl p-6 hover:border-slate-700 transition-all">
                  <div className="flex items-start gap-4">
                    <div className={cn(
                      "p-3 rounded-xl flex-shrink-0",
                      isSwitch ? "bg-amber-500/10" :
                      isAdd ? "bg-emerald-500/10" : "bg-blue-500/10"
                    )}>
                      {isSwitch ? <RefreshCw className="w-6 h-6 text-amber-400" /> :
                       isAdd ? <Plus className="w-6 h-6 text-emerald-400" /> :
                       <Minus className="w-6 h-6 text-blue-400" />}
                    </div>
                    <div className="flex-1">
                      <div className="flex items-center gap-3 mb-2">
                        <span className={cn(
                          "px-2.5 py-1 rounded-full text-xs font-medium",
                          isSwitch ? "bg-amber-500/10 text-amber-400" :
                          isAdd ? "bg-emerald-500/10 text-emerald-400" :
                          "bg-blue-500/10 text-blue-400"
                        )}>
                          {isSwitch ? "Switch Fund" : isAdd ? "Add New" : "Reduce Exposure"}
                        </span>
                        <div className="flex items-center gap-1">
                          <div className="w-16 h-1.5 bg-slate-800 rounded-full overflow-hidden">
                            <div className="h-full bg-emerald-500 rounded-full" style={{ width: rec.confidence + "%" }} />
                          </div>
                          <span className="text-xs text-slate-500">{rec.confidence}% confidence</span>
                        </div>
                      </div>

                      {isSwitch && rec.fromFund && rec.toFund && (
                        <div className="flex items-center gap-4 mb-3">
                          <div className="text-center">
                            <div className="text-sm font-medium text-slate-300">{rec.fromFund}</div>
                            <div className="text-xs text-red-400">Current</div>
                          </div>
                          <ArrowRight className="w-5 h-5 text-slate-500" />
                          <div className="text-center">
                            <div className="text-sm font-medium text-emerald-400">{rec.toFund}</div>
                            <div className="text-xs text-emerald-400">Recommended</div>
                          </div>
                        </div>
                      )}

                      <p className="text-sm text-slate-400 mb-4">{rec.reason}</p>

                      <div className="flex items-center justify-between">
                        <div className="flex gap-4">
                          <div className="flex items-center gap-1.5">
                            <TrendingUp className="w-4 h-4 text-emerald-400" />
                            <span className="text-sm text-emerald-400 font-medium">{rec.potentialReturn}</span>
                          </div>
                          <div className="flex items-center gap-1.5">
                            <Shield className="w-4 h-4 text-slate-400" />
                            <span className="text-sm text-slate-400">Risk: {rec.riskLevel}</span>
                          </div>
                        </div>
                        <button className="px-4 py-2 bg-emerald-500 hover:bg-emerald-600 text-white rounded-xl text-sm font-medium transition-all flex items-center gap-2">
                          Apply <ArrowRight className="w-4 h-4" />
                        </button>
                      </div>
                    </div>
                  </div>
                </motion.div>
              );
            })}
          </div>
        )}

        {/* PREDICTIONS TAB */}
        {activeTab === "predictions" && (
          <div className="space-y-6">
            <div className="flex items-center justify-between">
              <div>
                <h2 className="text-2xl font-bold text-white flex items-center gap-2">
                  <Target className="w-6 h-6 text-emerald-400" /> Predictive Analytics
                </h2>
                <p className="text-slate-400 mt-1">AI-powered future value projections based on historical patterns</p>
              </div>
              <div className="flex gap-2">
                {(["pessimistic", "base", "optimistic"] as const).map((scenario) => {
                  const isSelected = selectedPrediction === scenario;
                  return (
                    <button key={scenario} onClick={() => setSelectedPrediction(scenario)}
                      className={cn(
                        "px-4 py-2 rounded-xl text-sm font-medium capitalize transition-all",
                        isSelected
                          ? scenario === "optimistic" ? "bg-emerald-500/10 text-emerald-400 border border-emerald-500/20" :
                            scenario === "base" ? "bg-blue-500/10 text-blue-400 border border-blue-500/20" :
                            "bg-amber-500/10 text-amber-400 border border-amber-500/20"
                          : "text-slate-400 hover:bg-slate-800/50"
                      )}>
                      {scenario}
                    </button>
                  );
                })}
              </div>
            </div>

            <div className="grid md:grid-cols-3 gap-6">
              {predictions.filter(p => p.scenario === selectedPrediction).map((pred, idx) => (
                <motion.div key={idx} initial={{ opacity: 0, scale: 0.95 }} animate={{ opacity: 1, scale: 1 }} transition={{ delay: idx * 0.1 }}
                  className="bg-slate-900/60 border border-slate-800 rounded-2xl p-6">
                  <div className="flex items-center justify-between mb-4">
                    <span className="text-sm text-slate-400">{pred.period}</span>
                    <span className="px-2.5 py-1 bg-emerald-500/10 rounded-full text-xs text-emerald-400">{pred.confidence}% confidence</span>
                  </div>
                  <div className="text-3xl font-bold text-white mb-1">{formatCurrency(pred.projectedValue)}</div>
                  <div className="text-sm text-emerald-400 mb-4">+{pred.projectedReturns.toFixed(1)}% projected</div>
                  <div className="w-full h-2 bg-slate-800 rounded-full overflow-hidden">
                    <motion.div initial={{ width: 0 }} animate={{ width: pred.confidence + "%" }} transition={{ duration: 1, delay: 0.5 }}
                      className="h-full bg-gradient-to-r from-emerald-500 to-teal-400 rounded-full" />
                  </div>
                </motion.div>
              ))}
            </div>

            {/* Comparison Chart */}
            <div className="bg-slate-900/60 border border-slate-800 rounded-2xl p-6">
              <h3 className="font-semibold text-white mb-6">Scenario Comparison</h3>
              <div className="space-y-4">
                {["pessimistic", "base", "optimistic"].map((scenario) => {
                  const pred = predictions.find(p => p.period === "1 Year" && p.scenario === scenario);
                  if (!pred) return null;
                  const maxVal = 800000;
                  const width = (pred.projectedValue / maxVal) * 100;
                  const isOpt = scenario === "optimistic";
                  const isBase = scenario === "base";

                  return (
                    <div key={scenario} className="flex items-center gap-4">
                      <span className="w-24 text-sm text-slate-400 capitalize">{scenario}</span>
                      <div className="flex-1 h-8 bg-slate-800 rounded-lg overflow-hidden relative">
                        <motion.div initial={{ width: 0 }} animate={{ width: width + "%" }} transition={{ duration: 1 }}
                          className={cn(
                            "h-full rounded-lg",
                            isOpt ? "bg-emerald-500/30" :
                            isBase ? "bg-blue-500/30" : "bg-amber-500/30"
                          )} />
                        <span className="absolute inset-0 flex items-center px-3 text-sm font-medium text-white">
                          {formatCurrency(pred.projectedValue)}
                        </span>
                      </div>
                      <span className={cn(
                        "text-sm font-medium",
                        isOpt ? "text-emerald-400" :
                        isBase ? "text-blue-400" : "text-amber-400"
                      )}>+{pred.projectedReturns.toFixed(1)}%</span>
                    </div>
                  );
                })}
              </div>
            </div>
          </div>
        )}

        {/* RISK ANALYSIS TAB */}
        {activeTab === "risk" && (
          <div className="space-y-6">
            <div>
              <h2 className="text-2xl font-bold text-white flex items-center gap-2">
                <Shield className="w-6 h-6 text-emerald-400" /> Risk Analysis
              </h2>
              <p className="text-slate-400 mt-1">Comprehensive risk assessment across your portfolio</p>
            </div>

            <div className="grid md:grid-cols-2 gap-6">
              {/* Risk Score */}
              <motion.div initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }}
                className="bg-slate-900/60 border border-slate-800 rounded-2xl p-6">
                <h3 className="font-semibold text-white mb-4">Overall Risk Score</h3>
                <div className="flex items-center gap-6">
                  <ScoreRing score={62} size={140} />
                  <div className="space-y-3">
                    <div>
                      <div className="text-sm text-slate-400">Risk Level</div>
                      <div className="text-lg font-semibold text-amber-400">Moderate-High</div>
                    </div>
                    <div>
                      <div className="text-sm text-slate-400">Sharpe Ratio</div>
                      <div className="text-lg font-semibold text-white">0.82</div>
                    </div>
                    <div>
                      <div className="text-sm text-slate-400">Max Drawdown</div>
                      <div className="text-lg font-semibold text-red-400">-18.5%</div>
                    </div>
                  </div>
                </div>
              </motion.div>

              {/* Category Risk */}
              <motion.div initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }} transition={{ delay: 0.1 }}
                className="bg-slate-900/60 border border-slate-800 rounded-2xl p-6">
                <h3 className="font-semibold text-white mb-4">Category Risk Breakdown</h3>
                <div className="space-y-4">
                  {[
                    { category: "Small Cap", allocation: 28, risk: "Very High", score: 9.2, color: "bg-red-500" },
                    { category: "Mid Cap", allocation: 14, risk: "High", score: 7.8, color: "bg-amber-500" },
                    { category: "Large Cap", allocation: 17, risk: "Moderate", score: 5.5, color: "bg-blue-500" },
                    { category: "ELSS", allocation: 26, risk: "High", score: 7.2, color: "bg-amber-500" },
                    { category: "Balanced", allocation: 9, risk: "Moderate", score: 4.8, color: "bg-emerald-500" },
                    { category: "Liquid", allocation: 6, risk: "Low", score: 2.1, color: "bg-emerald-500" }
                  ].map((item, idx) => {
                    const isVeryHigh = item.risk === "Very High";
                    const isHigh = item.risk === "High";
                    const isModerate = item.risk === "Moderate";

                    return (
                      <div key={idx} className="flex items-center gap-4">
                        <div className="w-24 text-sm text-slate-300">{item.category}</div>
                        <div className="flex-1 h-6 bg-slate-800 rounded-lg overflow-hidden relative">
                          <motion.div initial={{ width: 0 }} animate={{ width: ((item.score / 10) * 100) + "%" }} transition={{ duration: 0.8, delay: idx * 0.1 }}
                            className={cn("h-full rounded-lg", item.color)} />
                          <span className="absolute inset-0 flex items-center px-2 text-xs text-white">{item.allocation}%</span>
                        </div>
                        <span className={cn(
                          "text-xs w-20 text-right",
                          isVeryHigh ? "text-red-400" :
                          isHigh ? "text-amber-400" :
                          isModerate ? "text-blue-400" : "text-emerald-400"
                        )}>{item.risk}</span>
                      </div>
                    );
                  })}
                </div>
              </motion.div>
            </div>

            {/* Risk Alerts */}
            <div className="bg-slate-900/60 border border-slate-800 rounded-2xl p-6">
              <h3 className="font-semibold text-white mb-4 flex items-center gap-2">
                <AlertTriangle className="w-5 h-5 text-amber-400" /> Risk Alerts
              </h3>
              <div className="space-y-3">
                {[
                  { level: "High", text: "Small cap concentration at 28% exceeds recommended 15% limit", action: "Rebalance Now" },
                  { level: "Medium", text: "Only 17% in large cap - consider increasing for stability", action: "View Suggestions" },
                  { level: "Low", text: "Good liquidity buffer with 6% in liquid funds", action: "Maintain" }
                ].map((alert, idx) => {
                  const isHighAlert = alert.level === "High";
                  const isMediumAlert = alert.level === "Medium";

                  return (
                    <div key={idx} className="flex items-center justify-between p-4 bg-slate-800/50 rounded-xl">
                      <div className="flex items-center gap-3">
                        <span className={cn(
                          "px-2.5 py-1 rounded-full text-xs font-medium",
                          isHighAlert ? "bg-red-500/10 text-red-400" :
                          isMediumAlert ? "bg-amber-500/10 text-amber-400" :
                          "bg-emerald-500/10 text-emerald-400"
                        )}>{alert.level}</span>
                        <span className="text-sm text-slate-300">{alert.text}</span>
                      </div>
                      <button className="text-sm text-emerald-400 hover:text-emerald-300 font-medium">{alert.action}</button>
                    </div>
                  );
                })}
              </div>
            </div>
          </div>
        )}
      </main>

      {/* AI Chat Panel */}
      <AIChatPanel isOpen={chatOpen} onClose={() => setChatOpen(false)} />

      {/* Floating AI Button */}
      {!chatOpen && (
        <motion.button initial={{ scale: 0 }} animate={{ scale: 1 }}
          onClick={() => setChatOpen(true)}
          className="fixed bottom-6 right-6 p-4 bg-emerald-500 hover:bg-emerald-600 text-white rounded-full shadow-lg shadow-emerald-500/20 z-40 transition-all hover:scale-110">
          <MessageCircle className="w-6 h-6" />
        </motion.button>
      )}
    </div>
  );
}