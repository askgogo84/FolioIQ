  { name: "Tata Liquid", returns: 6.8, allocation: 5, trend: "up", category: "Debt" },
];

const sipData = [
  { month: "Jan", sip: 25000 },
  { month: "Feb", sip: 25000 },
  { month: "Mar", sip: 25000 },
  { month: "Apr", sip: 25000 },
  { month: "May", sip: 25000 },
  { month: "Jun", sip: 25000 },
];

const insights = [
  { type: "success", title: "Optimal Allocation", message: "Your equity allocation is well-balanced for your moderate risk profile." },
  { type: "warning", title: "Rebalance Needed", message: "Consider increasing debt allocation by 5% for better stability." },
  { type: "info", title: "Outperformance", message: "3 of your funds are outperforming their benchmarks by 3.2%." },
  { type: "success", title: "Tax Saving", message: "You can save ₹45,000 more in taxes by investing in ELSS funds." },
];

const COLORS = ["#10b981", "#3b82f6", "#f59e0b", "#94a3b8"];

export default function DashboardPage() {
  const [timeRange, setTimeRange] = useState("1Y");
  const timeRanges = ["1M", "3M", "6M", "1Y", "ALL"];

