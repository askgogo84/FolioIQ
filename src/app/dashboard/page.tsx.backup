  { name: "SBI Small Cap", returns: 22.1, allocation: 20, trend: "up", category: "Equity" },
  { name: "HDFC Corporate", returns: 8.5, allocation: 15, trend: "down", category: "Debt" },
  { name: "ICICI Balanced", returns: 12.8, allocation: 15, trend: "up", category: "Hybrid" },
