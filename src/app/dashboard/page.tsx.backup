  { month: "Feb", value: 1080000, benchmark: 1035000 },
  { month: "Mar", value: 1120000, benchmark: 1050000 },
  { month: "Apr", value: 1100000, benchmark: 1040000 },
  { month: "May", value: 1150000, benchmark: 1070000 },
  { month: "Jun", value: 1180000, benchmark: 1090000 },
  { month: "Jul", value: 1200000, benchmark: 1105000 },
  { month: "Aug", value: 1230000, benchmark: 1120000 },
  { month: "Sep", value: 1210000, benchmark: 1110000 },
  { month: "Oct", value: 1240000, benchmark: 1135000 },
  { month: "Nov", value: 1260000, benchmark: 1150000 },
  { month: "Dec", value: 1250000, benchmark: 1145000 },
];

