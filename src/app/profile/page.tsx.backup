"use client";

import { useState } from "react";
import { 
  User, 
  Mail, 
  Phone, 
  MapPin, 
  Briefcase, 
  Shield,
  Edit3,
  Save,
  Camera
} from "lucide-react";

export default function ProfilePage() {
  const [isEditing, setIsEditing] = useState(false);
  const [profile, setProfile] = useState({
    name: "Govindhan M D",
    email: "govindhan@folioiq.com",
    phone: "+91 98765 43210",
    location: "Bangalore, India",
    occupation: "Software Engineer",
    riskAppetite: "Moderate",
    investmentGoal: "Wealth Creation",
    timeHorizon: "5-10 Years"
  });

  const riskLevels = ["Conservative", "Moderate", "Aggressive"];
  const goals = ["Wealth Creation", "Retirement", "Tax Saving", "Emergency Fund"];
  const horizons = ["1-3 Years", "3-5 Years", "5-10 Years", "10+ Years"];

  return (
    <div className="max-w-4xl mx-auto">
      <div className="mb-8">
        <h1 className="text-3xl font-bold text-slate-900">Profile</h1>
        <p className="text-slate-600 mt-1">Manage your account and investment preferences</p>
      </div>

      {/* Profile Card */}
      <div className="bg-white rounded-xl border border-slate-200 p-8 mb-6">
        <div className="flex items-start gap-6">
          <div className="relative">
            <div className="w-24 h-24 bg-emerald-100 rounded-full flex items-center justify-center">
              <User className="w-12 h-12 text-emerald-600" />
            </div>
            <button className="absolute bottom-0 right-0 w-8 h-8 bg-emerald-600 rounded-full flex items-center justify-center text-white hover:bg-emerald-700 transition-colors">
              <Camera className="w-4 h-4" />
            </button>
          </div>
          
          <div className="flex-1">
            <div className="flex justify-between items-start">
              <div>
                <h2 className="text-2xl font-bold text-slate-900">{profile.name}</h2>
                <p className="text-slate-600 mt-1">{profile.occupation}</p>
              </div>
              <button 
                onClick={() => setIsEditing(!isEditing)}
                className="px-4 py-2 bg-emerald-50 text-emerald-700 rounded-lg font-medium hover:bg-emerald-100 transition-colors flex items-center gap-2"
              >
                {isEditing ? <><Save className="w-4 h-4" /> Save</> : <><Edit3 className="w-4 h-4" /> Edit</>}
              </button>
            </div>

            <div className="grid sm:grid-cols-2 gap-4 mt-6">
              <div className="flex items-center gap-3 text-slate-600">
                <Mail className="w-5 h-5 text-slate-400" />
                <span>{profile.email}</span>
              </div>
              <div className="flex items-center gap-3 text-slate-600">
                <Phone className="w-5 h-5 text-slate-400" />
                <span>{profile.phone}</span>
              </div>
              <div className="flex items-center gap-3 text-slate-600">
                <MapPin className="w-5 h-5 text-slate-400" />
                <span>{profile.location}</span>
              </div>
              <div className="flex items-center gap-3 text-slate-600">
                <Briefcase className="w-5 h-5 text-slate-400" />
                <span>{profile.occupation}</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* Investment Preferences */}
      <div className="bg-white rounded-xl border border-slate-200 p-8">
        <div className="flex items-center gap-3 mb-6">
          <Shield className="w-6 h-6 text-emerald-600" />
          <h3 className="text-xl font-semibold text-slate-900">Investment Preferences</h3>
        </div>

        <div className="space-y-6">
          {/* Risk Appetite */}
          <div>
            <label className="block text-sm font-medium text-slate-700 mb-3">Risk Appetite</label>
            <div className="flex gap-3">
              {riskLevels.map((level) => (
                <button
                  key={level}
                  onClick={() => isEditing && setProfile({ ...profile, riskAppetite: level })}
                  disabled={!isEditing}
                  className={`
                    px-4 py-2 rounded-lg text-sm font-medium transition-all
                    ${profile.riskAppetite === level 
                      ? "bg-emerald-600 text-white" 
                      : "bg-slate-100 text-slate-600 hover:bg-slate-200"
                    }
                    ${!isEditing && "cursor-default"}
                  `}
                >
                  {level}
                </button>
              ))}
            </div>
          </div>

          {/* Investment Goal */}
          <div>
            <label className="block text-sm font-medium text-slate-700 mb-3">Investment Goal</label>
            <div className="flex flex-wrap gap-3">
              {goals.map((goal) => (
                <button
                  key={goal}
                  onClick={() => isEditing && setProfile({ ...profile, investmentGoal: goal })}
                  disabled={!isEditing}
                  className={`
                    px-4 py-2 rounded-lg text-sm font-medium transition-all
                    ${profile.investmentGoal === goal 
                      ? "bg-emerald-600 text-white" 
                      : "bg-slate-100 text-slate-600 hover:bg-slate-200"
                    }
                    ${!isEditing && "cursor-default"}
                  `}
                >
                  {goal}
                </button>
              ))}
            </div>
          </div>

          {/* Time Horizon */}
          <div>
            <label className="block text-sm font-medium text-slate-700 mb-3">Time Horizon</label>
            <div className="flex gap-3">
              {horizons.map((horizon) => (
                <button
                  key={horizon}
                  onClick={() => isEditing && setProfile({ ...profile, timeHorizon: horizon })}
                  disabled={!isEditing}
                  className={`
                    px-4 py-2 rounded-lg text-sm font-medium transition-all
                    ${profile.timeHorizon === horizon 
                      ? "bg-emerald-600 text-white" 
                      : "bg-slate-100 text-slate-600 hover:bg-slate-200"
                    }
                    ${!isEditing && "cursor-default"}
                  `}
                >
                  {horizon}
                </button>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}
